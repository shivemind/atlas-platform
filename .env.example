# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/atlas_platform?schema=public"

# ── Service Port ─────────────────────────────────────────────────────
PORT=3005

# ── Upstash Redis (rate-limit, idempotency, cron locks) ─────────────
REDIS_REST_URL=
REDIS_REST_TOKEN=

# ── Cron Secret ──────────────────────────────────────────────────────
CRON_SECRET="changeme"

# ── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Idempotency ──────────────────────────────────────────────────────
IDEMPOTENCY_TTL_SECONDS=86400

# ── Webhook Retry ────────────────────────────────────────────────────
WEBHOOK_RETRY_BASE_SECONDS=30
WEBHOOK_RETRY_MAX_SECONDS=3600
